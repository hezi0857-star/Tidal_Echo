# ───────────────────────────────────────────────────────────────────────────
#  Paste these two location blocks INSIDE your existing TLS server block, e.g.
#
#    server {
#        listen 443 ssl;
#        server_name your-domain.example;
#        ssl_certificate     /etc/letsencrypt/live/your-domain.example/fullchain.pem;
#        ssl_certificate_key /etc/letsencrypt/live/your-domain.example/privkey.pem;
#        ...
#        <PASTE HERE>
#    }
#
#  HTTPS is mandatory: PWA install, Service Worker, and Web Push all require it.
#  If you change the prefixes below, change RELAY_PUBLIC_PREFIX (=/relay) and
#  RELAY_APP_PATH (=/chat/) in relay.env to match.
# ───────────────────────────────────────────────────────────────────────────

# API — reverse proxy to the relay. SSE-friendly: no buffering, long timeouts.
location /relay/ {
    client_max_body_size 10m;                 # must be >= RELAY_MAX_UPLOAD_BYTES
    proxy_pass http://127.0.0.1:3011/;        # trailing slash strips the /relay/ prefix
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header Connection '';           # keep SSE connections open
    proxy_buffering off;                      # stream events immediately
    proxy_cache off;
    chunked_transfer_encoding off;
    proxy_read_timeout 3600s;                 # SSE streams live for a long time
    proxy_send_timeout 3600s;
}

# PWA static files. Point the alias at wherever you deploy the frontend.
location = /chat { return 301 /chat/; }
location /chat/ {
    alias /var/www/companion-web/;
    index index.html;
}
location = /chat/manifest.webmanifest {
    alias /var/www/companion-web/manifest.webmanifest;
    default_type application/manifest+json;
}
