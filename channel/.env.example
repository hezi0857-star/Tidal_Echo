# companion channel plugin — local secrets (do NOT commit)
# Lives at:  <RELAY_STATE_DIR>/.env   (default: ~/.claude/channels/companion/.env)
# The CC-spawned plugin process inherits no environment, so it reads this file.

# Shared secret — must EXACTLY match the relay backend's RELAY_SECRET:
RELAY_SECRET=

# Your relay's public API base (your domain + the nginx /relay/ prefix):
RELAY_URL=https://your-domain.example/relay

# Names — keep these the same as the backend's, for consistent narration:
RELAY_AI_NAME=Claude
RELAY_HUMAN_NAME=你的名字

# Optional: channel id / registration name (default: companion).
# If you change it, also use server:<name> in the launch flag and .mcp.json.
RELAY_CHANNEL_NAME=companion
